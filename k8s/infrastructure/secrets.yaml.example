apiVersion: v1
kind: Secret
metadata:
  name: langconnect-secrets
  namespace: langconnect
type: Opaque
stringData:
  # MySQL
  MYSQL_ROOT_PASSWORD: "CHANGE_ME"
  MYSQL_DATABASE: "langconnect"
  MYSQL_USER: "langconnect"
  MYSQL_PASSWORD: "CHANGE_ME"

  # Laravel - generate with: php artisan key:generate --show
  APP_KEY: "base64:CHANGE_ME"

  # Reverb WebSocket - generate random strings
  REVERB_APP_ID: "langconnect"
  REVERB_APP_KEY: "CHANGE_ME"
  REVERB_APP_SECRET: "CHANGE_ME"
