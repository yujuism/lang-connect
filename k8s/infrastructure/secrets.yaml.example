apiVersion: v1
kind: Secret
metadata:
  name: langconnect-secrets
  namespace: langconnect
type: Opaque
stringData:
  # MySQL (shared database)
  DB_HOST: "shared-mysql.shared-db.svc.cluster.local"
  MYSQL_DATABASE: "langconnect"
  MYSQL_USER: "langconnect"
  MYSQL_PASSWORD: "CHANGE_ME"

  # Laravel - generate with: php artisan key:generate --show
  APP_KEY: "base64:CHANGE_ME"

  # Reverb WebSocket - generate random strings
  REVERB_APP_ID: "langconnect"
  REVERB_APP_KEY: "CHANGE_ME"
  REVERB_APP_SECRET: "CHANGE_ME"

  # MinIO (S3-compatible storage for PDFs) - external service
  MINIO_ACCESS_KEY: "CHANGE_ME"
  MINIO_SECRET_KEY: "CHANGE_ME"
  MINIO_BUCKET: "langconnect-pdfs"
  MINIO_REGION: "us-east-1"
  MINIO_ENDPOINT: "https://s3.cloudsynth.site"
  MINIO_URL: "https://s3.cloudsynth.site"

  # Groq AI (Voice transcription & session analysis)
  # Get your API key at https://console.groq.com
  GROQ_API_KEY: "gsk_CHANGE_ME"
